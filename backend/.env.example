# Copy to .env and change values. Do not commit .env.
# ENVIRONMENT=production (enables strict checks, secure cookies behind HTTPS)
# ENVIRONMENT=development (default; relaxed)
ENVIRONMENT=development
SECRET_KEY=generate-with-openssl-rand-hex-32
AGENT_TOKEN=long-random-string-for-agents
# Server-side pepper for hashing per-agent token secrets (required in production).
AGENT_TOKEN_PEPPER=generate-with-openssl-rand-hex-32
# Optional: allow old agent tokens during migration (comma-separated)
# AGENT_LEGACY_TOKENS=dev-agent-token-change-in-production
# PostgreSQL (одна БД для inventory, diagrams и warehouse; при необходимости задайте отдельные URL).
DATABASE_URL=postgresql+asyncpg://inventory:inventory@localhost:5432/inventory
DIAGRAMS_DATABASE_URL=postgresql+asyncpg://inventory:inventory@localhost:5432/inventory
WAREHOUSE_DATABASE_URL=postgresql+asyncpg://inventory:inventory@localhost:5432/inventory
# Пароль суперпользователя postgres (для первичного создания БД inventory)
# POSTGRES_ADMIN_USER=postgres
# POSTGRES_ADMIN_PASSWORD=ваш-пароль-при-установке-postgres
# Путь к pg_dump/pg_restore, если не в PATH (Windows):
# PG_BIN_DIR=C:\Program Files\PostgreSQL\18\bin
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# Rate limits (slowapi); disabled when ENVIRONMENT=test
# RATE_LIMIT_LOGIN=10/minute
# RATE_LIMIT_AGENT=120/minute
# Dev-only: accept any Bearer on /agent/inventory (unsafe; default off)
# ALLOW_DEV_ANY_AGENT_TOKEN=false
# Production: OpenAPI /docs off unless enabled
# ENABLE_OPENAPI=false
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_PASSWORD=change-me
# AGENT_INBOX_DIR=agent_inbox   (set empty to disable raw payload dumps)
# AGENT_INBOX_RETENTION_DAYS=7
# LDAP_URI=ldap://dc01.example.local
# LDAP_BIND_DN=CN=svc-inventory,OU=Service Accounts,DC=example,DC=local
# LDAP_BIND_PASSWORD=change-me
# LDAP_USER_SEARCH_BASE=OU=Users,DC=example,DC=local
# LDAP_USER_FILTER=(&(objectClass=user)(objectCategory=person))
# LDAP_USERNAME_ATTR=sAMAccountName
# LDAP_DISPLAY_NAME_ATTR=displayName
# LDAP_EMAIL_ATTR=mail
# LDAP_SYNC_LIMIT=500

# BITRIX24_WEBHOOK_URL=https://your.bitrix24.ru/rest/1/xxxxxxxxxxxx

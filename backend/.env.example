# Copy to backend/.env — единственный файл секретов (local + Docker).
# Do not commit .env.
#
# Docker:
#   cp backend/.env.example backend/.env
#   # заполните секреты ниже (openssl rand -hex 32)
#   npm run docker:up | docker:down | docker:restart
#
# Local without Docker: npm start (читает этот же файл).

# --- Режим ---
# development | production | test
# В Docker Compose ENVIRONMENT принудительно production в контейнере.
ENVIRONMENT=development

# --- Обязательные секреты (production / Docker) ---
SECRET_KEY=generate-with-openssl-rand-hex-32
AGENT_TOKEN=long-random-string-for-agents-min-24-chars
AGENT_TOKEN_PEPPER=generate-with-openssl-rand-hex-32
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-me-strong-password-min-12
# Optional: comma-separated old shared agent tokens during migration
# AGENT_LEGACY_TOKENS=

# CORS для панели (добавьте LAN IP: http://192.168.x.x:3000)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# --- PostgreSQL: локальный хост (npm start) ---
DATABASE_URL=postgresql+asyncpg://inventory:inventory@localhost:5432/inventory
DIAGRAMS_DATABASE_URL=postgresql+asyncpg://inventory:inventory@localhost:5432/inventory
WAREHOUSE_DATABASE_URL=postgresql+asyncpg://inventory:inventory@localhost:5432/inventory
# POSTGRES_ADMIN_USER=postgres
# POSTGRES_ADMIN_PASSWORD=ваш-пароль-при-установке-postgres
# Windows: PG_BIN_DIR=C:\Program Files\PostgreSQL\16\bin
# Linux:   PG_BIN_DIR=/usr/lib/postgresql/16/bin

# --- PostgreSQL: Docker Compose (сервис db) ---
POSTGRES_USER=inventory
POSTGRES_PASSWORD=generate-with-openssl-rand-hex-32
POSTGRES_DB=inventory
POSTGRES_PUBLISH_PORT=127.0.0.1:5433
CORAX_PUBLISH_PORT=3000

# --- Backup sidecar (Docker) ---
BACKUP_SCHEDULE=@daily
BACKUP_KEEP_DAYS=14
BACKUP_KEEP_WEEKS=4
BACKUP_KEEP_MONTHS=3

# --- Hardening ---
# Пустой AGENT_INBOX_DIR = не писать сырые payload на диск
AGENT_INBOX_DIR=
ALLOW_LEGACY_AGENT_TOKEN_HASHES=false
ENABLE_OPENAPI=false
# ALLOW_DEV_ANY_AGENT_TOKEN=false
# WOL_FORCE_DISABLED=false

# Rate limits (slowapi); disabled when ENVIRONMENT=test
# RATE_LIMIT_LOGIN=10/minute
# RATE_LIMIT_AGENT=120/minute
# RATE_LIMIT_WAKE=5/minute
# RATE_LIMIT_PING=30/minute

# Fleet ICMP
# COMPUTER_PING_ENABLED=true
# COMPUTER_PING_INTERVAL_MINUTES=15

# LDAP (directory sync only — not panel login)
# LDAP_URI=ldap://dc01.example.local
# LDAP_BIND_DN=CN=svc-inventory,OU=Service Accounts,DC=example,DC=local
# LDAP_BIND_PASSWORD=change-me
# LDAP_USER_SEARCH_BASE=OU=Users,DC=example,DC=local

# Bitrix24
# BITRIX24_WEBHOOK_URL=https://your.bitrix24.ru/rest/1/xxxxxxxxxxxx
# BITRIX24_BOT_ID=
# BITRIX24_BOT_CLIENT_ID=
# BITRIX24_BOT_HANDLER_TOKEN=

# WikiRAG / LM Studio
# LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# LM_STUDIO_DOCKER_URL=http://host.docker.internal:1234/v1
# LM_STUDIO_MODEL=google/gemma-3-1b
# LM_STUDIO_MAX_TOKENS=3072

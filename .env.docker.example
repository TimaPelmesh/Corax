# Устарело как отдельный файл.
# Единый источник секретов: backend/.env
#
# Рекомендуется:
#   npm run docker:up
#   → scripts/ensure_docker_env.py создаст backend/.env с сильными секретами
#
# Вручную:
#   python scripts/ensure_docker_env.py
#   # или: cp backend/.env.example backend/.env и заполните секреты
#   npm run docker:up
